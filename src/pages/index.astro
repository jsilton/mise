---
import Layout from '../layouts/Layout.astro';
import SearchBar from '../components/SearchBar.astro';
import FilterPanel from '../components/FilterPanel.astro';
import RecipeCard from '../components/RecipeCard.astro';
import { getCollection } from 'astro:content';
import type { RecipeSearchItem } from '../lib/fuzzySearch';

const recipes = await getCollection('recipes');
recipes.sort((a, b) => a.data.title.localeCompare(b.data.title));

// Prepare search index data - convert recipes to searchable format
const searchIndexData: RecipeSearchItem[] = recipes.map((recipe) => ({
  slug: recipe.slug,
  title: recipe.data.title,
  cuisines: recipe.data.cuisines,
  ingredients: recipe.data.ingredients,
  flavorProfile: recipe.data.flavorProfile,
  cookingMethods: recipe.data.cookingMethods,
  origin: recipe.data.origin,
}));
---

<Layout title="Mise | Recipe Codex">
  <!-- Page Header -->
  <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-10 gap-6">
    <div>
      <h1
        class="text-3xl font-display font-semibold tracking-tight"
        style="color: var(--text-primary);"
      >
        The Codex
      </h1>
      <p class="mt-1.5 text-sm" style="color: var(--text-secondary);">
        Exploring <span style="color: var(--accent-gold);">{recipes.length}</span> family recipes.
      </p>
    </div>
    <div class="w-full md:w-80">
      <SearchBar id="searchInput" placeholder="Search by name or ingredient..." />
    </div>
  </div>

  <!-- Filter and Sort UI -->
  <FilterPanel {recipes} />

  <!-- Recipe Grid -->
  <div id="recipeGrid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    {recipes.map((recipe) => <RecipeCard {recipe} />)}
  </div>

  <!-- No Results State -->
  <div id="noResults" class="hidden text-center py-20">
    <div
      class="inline-flex items-center justify-center w-16 h-16 rounded-full mb-4"
      style="background: var(--bg-elevated);"
    >
      <svg
        class="w-8 h-8"
        style="color: var(--text-tertiary);"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
        ></path>
      </svg>
    </div>
    <h3 class="text-lg font-medium" style="color: var(--text-primary);">No recipes found</h3>
    <p class="mt-1" style="color: var(--text-secondary);">
      Try adjusting your search terms or filters.
    </p>
    <button
      id="clearSearch"
      class="mt-4 text-sm font-medium hover:underline"
      style="color: var(--accent-gold);"
    >
      Clear search
    </button>
  </div>
</Layout>

<script define:vars={{ searchIndexData }}>
  window.__searchIndexData = searchIndexData;
</script>

<script>
  import Fuse from 'fuse.js';

  // Initialize fuzzy search index from server-injected data
  const searchIndexData = (window as any).__searchIndexData;
  const fuse = new Fuse(searchIndexData, {
    keys: [
      { name: 'title', weight: 10 },
      { name: 'ingredients', weight: 5 },
      { name: 'cuisines', weight: 3 },
      { name: 'flavorProfile', weight: 2 },
      { name: 'cookingMethods', weight: 2 },
      { name: 'origin', weight: 2 },
    ],
    threshold: 0.35,
    minMatchCharLength: 2,
    includeScore: true,
  });

  const searchInput = document.getElementById('searchInput') as HTMLInputElement | null;
  const recipeCards = document.querySelectorAll('.recipe-card');
  const noResults = document.getElementById('noResults');
  const clearSearchBtn = document.getElementById('clearSearch');

  function updateUrlParams() {
    const params = new URLSearchParams();
    const query = searchInput?.value?.trim() || '';
    if (query) {
      params.set('q', query);
    }

    const state = (window as any).filterState || {};
    if (state.difficulty) params.set('difficulty', state.difficulty);
    if (state.role) params.set('role', state.role);
    if (state.vibe) params.set('vibe', state.vibe);
    if (state.cuisine) params.set('cuisine', state.cuisine);
    if (state.dietary) params.set('dietary', state.dietary);
    if (state.cookingMethod) params.set('method', state.cookingMethod);
    if (state.occasion) params.set('occasion', state.occasion);
    if (state.flavor) params.set('flavor', state.flavor);
    if (state.sortMode && state.sortMode !== 'title') {
      params.set('sort', state.sortMode);
    }

    const queryString = params.toString();
    const newUrl = queryString ? `?${queryString}` : window.location.pathname;
    history.replaceState(null, '', newUrl);
  }

  function applyFiltersAndSort() {
    const query = searchInput?.value?.toLowerCase() || '';
    const state = (window as any).filterState || {};

    let visibleCards: { card: Element; difficulty: string; prepTime: string }[] = [];

    if (query.trim()) {
      const fuzzyResults = fuse.search(query.trim());
      const fuzzySlugSet = new Set(fuzzyResults.map((r) => r.item.slug));

      recipeCards.forEach((card) => {
        const el = card as HTMLElement;
        const slug = el.getAttribute('href')?.split('/').pop();
        const cardDifficulty = el.dataset.difficulty || '';
        const cardRole = el.dataset.role || '';
        const cardVibe = el.dataset.vibe || '';
        const cardCuisines = el.dataset.cuisines?.split(',').filter((c) => c) || [];
        const cardDietary = el.dataset.dietary?.split(',').filter((d) => d) || [];
        const cardMethods = el.dataset.cookingMethods?.split(',').filter((m) => m) || [];
        const cardOccasions = el.dataset.occasions?.split(',').filter((o) => o) || [];
        const cardFlavors = el.dataset.flavorProfile?.split(',').filter((f) => f) || [];

        const matchesFuzzySearch = fuzzySlugSet.has(slug);
        const matchesDifficulty = !state.difficulty || cardDifficulty === state.difficulty;
        const matchesRole = !state.role || cardRole === state.role;
        const matchesVibe = !state.vibe || cardVibe === state.vibe;
        const matchesCuisine = !state.cuisine || cardCuisines.includes(state.cuisine);
        const matchesDietary = !state.dietary || cardDietary.includes(state.dietary);
        const matchesMethod = !state.cookingMethod || cardMethods.includes(state.cookingMethod);
        const matchesOccasion = !state.occasion || cardOccasions.includes(state.occasion);
        const matchesFlavor = !state.flavor || cardFlavors.includes(state.flavor);

        const isVisible =
          matchesFuzzySearch &&
          matchesDifficulty &&
          matchesRole &&
          matchesVibe &&
          matchesCuisine &&
          matchesDietary &&
          matchesMethod &&
          matchesOccasion &&
          matchesFlavor;

        if (isVisible) {
          el.style.display = 'flex';
          visibleCards.push({
            card: el,
            difficulty: cardDifficulty,
            prepTime: el.dataset.prepTime || '',
          });
        } else {
          el.style.display = 'none';
        }
      });
    } else {
      recipeCards.forEach((card) => {
        const el = card as HTMLElement;
        const cardDifficulty = el.dataset.difficulty || '';
        const cardRole = el.dataset.role || '';
        const cardVibe = el.dataset.vibe || '';
        const cardCuisines = el.dataset.cuisines?.split(',').filter((c) => c) || [];
        const cardDietary = el.dataset.dietary?.split(',').filter((d) => d) || [];
        const cardMethods = el.dataset.cookingMethods?.split(',').filter((m) => m) || [];
        const cardOccasions = el.dataset.occasions?.split(',').filter((o) => o) || [];
        const cardFlavors = el.dataset.flavorProfile?.split(',').filter((f) => f) || [];

        const matchesDifficulty = !state.difficulty || cardDifficulty === state.difficulty;
        const matchesRole = !state.role || cardRole === state.role;
        const matchesVibe = !state.vibe || cardVibe === state.vibe;
        const matchesCuisine = !state.cuisine || cardCuisines.includes(state.cuisine);
        const matchesDietary = !state.dietary || cardDietary.includes(state.dietary);
        const matchesMethod = !state.cookingMethod || cardMethods.includes(state.cookingMethod);
        const matchesOccasion = !state.occasion || cardOccasions.includes(state.occasion);
        const matchesFlavor = !state.flavor || cardFlavors.includes(state.flavor);

        const isVisible =
          matchesDifficulty &&
          matchesRole &&
          matchesVibe &&
          matchesCuisine &&
          matchesDietary &&
          matchesMethod &&
          matchesOccasion &&
          matchesFlavor;

        if (isVisible) {
          el.style.display = 'flex';
          visibleCards.push({
            card: el,
            difficulty: cardDifficulty,
            prepTime: el.dataset.prepTime || '',
          });
        } else {
          el.style.display = 'none';
        }
      });
    }

    // Apply sorting
    if (state.sortMode === 'prepTime') {
      visibleCards.sort((a, b) => parseInt(a.prepTime || '0') - parseInt(b.prepTime || '0'));
    } else if (state.sortMode === 'difficulty') {
      const diffOrder: Record<string, number> = { easy: 0, intermediate: 1, hard: 2 };
      visibleCards.sort(
        (a, b) => (diffOrder[a.difficulty] ?? 99) - (diffOrder[b.difficulty] ?? 99)
      );
    }

    // Reorder cards in grid
    const grid = document.getElementById('recipeGrid');
    visibleCards.forEach(({ card }) => grid?.appendChild(card));

    // Toggle no results message
    if (noResults) {
      noResults.style.display = visibleCards.length === 0 ? 'block' : 'none';
    }

    // Synchronize to URL query parameters
    updateUrlParams();
  }

  // Expose globally so FilterPanel can call it
  (window as any).applyFiltersAndSort = applyFiltersAndSort;

  // Search input listener
  searchInput?.addEventListener('input', applyFiltersAndSort);

  function setSelectFromParam(id: string, value: string | null) {
    if (!value) return;
    const select = document.getElementById(id) as HTMLSelectElement | null;
    if (!select) return;
    const hasOption = Array.from(select.options).some((option) => option.value === value);
    if (hasOption) select.value = value;
  }

  function applyInitialUrlState() {
    const params = new URLSearchParams(window.location.search);
    const query = params.get('q') || params.get('search');
    if (query && searchInput) searchInput.value = query;

    setSelectFromParam('filterDifficulty', params.get('difficulty'));
    setSelectFromParam('filterRole', params.get('role'));
    setSelectFromParam('filterVibe', params.get('vibe'));
    setSelectFromParam('filterCuisine', params.get('cuisine'));
    setSelectFromParam('filterDietary', params.get('dietary'));
    setSelectFromParam('filterCookingMethod', params.get('method') || params.get('cookingMethod'));
    setSelectFromParam('filterOccasion', params.get('occasion'));
    setSelectFromParam('filterFlavor', params.get('flavor'));
    setSelectFromParam('sortBy', params.get('sort') || params.get('sortMode'));
  }

  // Clear search button
  clearSearchBtn?.addEventListener('click', () => {
    if (searchInput) searchInput.value = '';
    applyFiltersAndSort();
    searchInput?.focus();
  });

  // Initial state update and render
  applyInitialUrlState();
  (window as any).updateFilterState?.();
  applyFiltersAndSort();
</script>
