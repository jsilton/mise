---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const meals = await getCollection('meals');
  return meals.map((meal) => ({
    params: { slug: meal.slug },
    props: { meal },
  }));
}

const { meal } = Astro.props;
const { Content } = await meal.render();

// Get recipe collection for linking
const recipes = await getCollection('recipes');
const recipeMap = new Map(recipes.map((r) => [r.slug, r]));

// Helper to get recipe details
function getRecipe(slug: string) {
  return recipeMap.get(slug);
}

function getRecipeTitle(slug: string): string {
  const recipe = recipeMap.get(slug);
  return recipe?.data.title || slug;
}

// Template display info
const templateLabels: Record<string, string> = {
  plate: 'Plate',
  bowl: 'Bowl',
  'pasta-night': 'Pasta Night',
  'soup-and-side': 'Soup & Side',
  'one-pot': 'One-Pot',
  grazing: 'Grazing',
};

const templateColors: Record<string, { bg: string; text: string }> = {
  plate: { bg: 'rgba(251,113,133,0.12)', text: '#FDA4AF' },
  bowl: { bg: 'rgba(251,191,36,0.12)', text: '#FCD34D' },
  'pasta-night': { bg: 'rgba(239,68,68,0.12)', text: '#FCA5A5' },
  'soup-and-side': { bg: 'rgba(52,211,153,0.12)', text: '#6EE7B7' },
  'one-pot': { bg: 'rgba(167,139,250,0.12)', text: '#C4B5FD' },
  grazing: { bg: 'rgba(129,140,248,0.12)', text: '#A5B4FC' },
};
---

<Layout title={`${meal.data.title} | Meals | Mise`}>
  <div class="max-w-3xl mx-auto">
    {/* Breadcrumb */}
    <nav class="mb-8">
      <a
        href={`${import.meta.env.BASE_URL}meals`}
        class="breadcrumb-link inline-flex items-center gap-1.5 text-sm transition-colors"
        style="color: var(--text-tertiary);"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"
          ></path>
        </svg>
        Back to Meals
      </a>
    </nav>

    {/* Header Card */}
    <header
      class="mb-8 rounded-2xl overflow-hidden"
      style={`background: linear-gradient(to bottom, var(--bg-elevated), var(--bg-surface)); border: 1px solid var(--border-subtle);`}
    >
      <div class="p-6 sm:p-8">
        <div class="flex items-start justify-between gap-4 mb-5">
          <h1
            class="font-display text-2xl sm:text-3xl font-bold tracking-tight leading-tight"
            style="color: var(--text-primary);"
          >
            {meal.data.title}
          </h1>
          {
            meal.data.template && (
              <span
                class="shrink-0 inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold uppercase tracking-wide"
                style={`background: ${templateColors[meal.data.template]?.bg || 'var(--bg-hover)'}; color: ${templateColors[meal.data.template]?.text || 'var(--text-secondary)'};`}
              >
                {templateLabels[meal.data.template] || meal.data.template}
              </span>
            )
          }
        </div>

        {/* Time Info */}
        {
          (meal.data.totalPrepTime || meal.data.totalCookTime || meal.data.totalActiveTime) && (
            <div class="flex flex-wrap gap-6 text-sm">
              {meal.data.totalActiveTime && (
                <div class="flex items-center gap-2">
                  <svg
                    class="w-4 h-4"
                    style="color: var(--accent-gold);"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                    />
                  </svg>
                  <span style="color: var(--text-tertiary);">Active:</span>
                  <span class="font-medium" style="color: var(--text-secondary);">
                    {meal.data.totalActiveTime}
                  </span>
                </div>
              )}
              {meal.data.totalPrepTime && (
                <div class="flex items-center gap-2">
                  <span style="color: var(--text-tertiary);">Prep:</span>
                  <span class="font-medium" style="color: var(--text-secondary);">
                    {meal.data.totalPrepTime}
                  </span>
                </div>
              )}
              {meal.data.totalCookTime && (
                <div class="flex items-center gap-2">
                  <span style="color: var(--text-tertiary);">Cook:</span>
                  <span class="font-medium" style="color: var(--text-secondary);">
                    {meal.data.totalCookTime}
                  </span>
                </div>
              )}
            </div>
          )
        }
      </div>
    </header>

    {/* Recipe Components */}
    <section class="mb-8">
      <h2
        class="text-xs font-semibold uppercase tracking-wider mb-3"
        style="color: var(--text-tertiary);"
      >
        Recipes in This Meal
      </h2>
      <div
        class="rounded-xl overflow-hidden"
        style={`background: var(--bg-surface); border: 1px solid var(--border-subtle);`}
      >
        {
          meal.data.main && (
            <a
              href={`${import.meta.env.BASE_URL}recipes/${meal.data.main}`}
              class="recipe-link flex items-center gap-4 p-4 transition-colors group"
              style={`border-bottom: 1px solid var(--border-subtle);`}
            >
              <span
                class="w-20 flex-shrink-0 text-xs font-semibold uppercase tracking-wider"
                style="color: var(--text-tertiary);"
              >
                Main
              </span>
              <span
                class="recipe-link-name flex-1 font-medium transition-colors"
                style="color: var(--text-primary);"
              >
                {getRecipeTitle(meal.data.main)}
              </span>
              <svg
                class="recipe-link-arrow w-4 h-4"
                style="color: var(--text-tertiary);"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 5l7 7-7 7"
                />
              </svg>
            </a>
          )
        }

        {
          meal.data.sides &&
            meal.data.sides.map((side) => (
              <a
                href={`${import.meta.env.BASE_URL}recipes/${side}`}
                class="recipe-link flex items-center gap-4 p-4 transition-colors group"
                style={`border-bottom: 1px solid var(--border-subtle);`}
              >
                <span
                  class="w-20 flex-shrink-0 text-xs font-semibold uppercase tracking-wider"
                  style="color: var(--text-tertiary);"
                >
                  Side
                </span>
                <span
                  class="recipe-link-name flex-1 font-medium transition-colors"
                  style="color: var(--text-primary);"
                >
                  {getRecipeTitle(side)}
                </span>
                <svg
                  class="recipe-link-arrow w-4 h-4"
                  style="color: var(--text-tertiary);"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 5l7 7-7 7"
                  />
                </svg>
              </a>
            ))
        }

        {
          meal.data.base && (
            <a
              href={`${import.meta.env.BASE_URL}recipes/${meal.data.base}`}
              class="recipe-link flex items-center gap-4 p-4 transition-colors group"
              style={`border-bottom: 1px solid var(--border-subtle);`}
            >
              <span
                class="w-20 flex-shrink-0 text-xs font-semibold uppercase tracking-wider"
                style="color: var(--text-tertiary);"
              >
                Base
              </span>
              <span
                class="recipe-link-name flex-1 font-medium transition-colors"
                style="color: var(--text-primary);"
              >
                {getRecipeTitle(meal.data.base)}
              </span>
              <svg
                class="recipe-link-arrow w-4 h-4"
                style="color: var(--text-tertiary);"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 5l7 7-7 7"
                />
              </svg>
            </a>
          )
        }

        {
          meal.data.salad && (
            <a
              href={`${import.meta.env.BASE_URL}recipes/${meal.data.salad}`}
              class="recipe-link flex items-center gap-4 p-4 transition-colors group"
              style={`border-bottom: 1px solid var(--border-subtle);`}
            >
              <span
                class="w-20 flex-shrink-0 text-xs font-semibold uppercase tracking-wider"
                style="color: var(--text-tertiary);"
              >
                Salad
              </span>
              <span
                class="recipe-link-name flex-1 font-medium transition-colors"
                style="color: var(--text-primary);"
              >
                {getRecipeTitle(meal.data.salad)}
              </span>
              <svg
                class="recipe-link-arrow w-4 h-4"
                style="color: var(--text-tertiary);"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 5l7 7-7 7"
                />
              </svg>
            </a>
          )
        }

        {
          meal.data.sauce && (
            <a
              href={`${import.meta.env.BASE_URL}recipes/${meal.data.sauce}`}
              class="recipe-link flex items-center gap-4 p-4 transition-colors group"
              style={`border-bottom: 1px solid var(--border-subtle);`}
            >
              <span
                class="w-20 flex-shrink-0 text-xs font-semibold uppercase tracking-wider"
                style="color: var(--text-tertiary);"
              >
                Sauce
              </span>
              <span
                class="recipe-link-name flex-1 font-medium transition-colors"
                style="color: var(--text-primary);"
              >
                {getRecipeTitle(meal.data.sauce)}
              </span>
              <svg
                class="recipe-link-arrow w-4 h-4"
                style="color: var(--text-tertiary);"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 5l7 7-7 7"
                />
              </svg>
            </a>
          )
        }

        {
          meal.data.dessert && (
            <a
              href={`${import.meta.env.BASE_URL}recipes/${meal.data.dessert}`}
              class="recipe-link flex items-center gap-4 p-4 transition-colors group"
            >
              <span
                class="w-20 flex-shrink-0 text-xs font-semibold uppercase tracking-wider"
                style="color: var(--text-tertiary);"
              >
                Dessert
              </span>
              <span
                class="recipe-link-name flex-1 font-medium transition-colors"
                style="color: var(--text-primary);"
              >
                {getRecipeTitle(meal.data.dessert)}
              </span>
              <svg
                class="recipe-link-arrow w-4 h-4"
                style="color: var(--text-tertiary);"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 5l7 7-7 7"
                />
              </svg>
            </a>
          )
        }
      </div>
    </section>

    {/* Best For Days */}
    {
      meal.data.bestFor && meal.data.bestFor.length > 0 && (
        <section class="mb-6">
          <h2
            class="text-xs font-semibold uppercase tracking-wider mb-3"
            style="color: var(--text-tertiary);"
          >
            Best For
          </h2>
          <div class="flex flex-wrap gap-2">
            {meal.data.bestFor.map((day) => (
              <span
                class="inline-flex items-center px-3 py-1.5 text-sm font-medium rounded-lg"
                style="background: rgba(201,169,97,0.12); color: var(--accent-gold); border: 1px solid rgba(201,169,97,0.2);"
              >
                {day}
              </span>
            ))}
          </div>
        </section>
      )
    }

    {/* Cuisines */}
    {
      meal.data.cuisines && meal.data.cuisines.length > 0 && (
        <section class="mb-8">
          <h2
            class="text-xs font-semibold uppercase tracking-wider mb-3"
            style="color: var(--text-tertiary);"
          >
            Cuisines
          </h2>
          <div class="flex flex-wrap gap-2">
            {meal.data.cuisines.map((cuisine) => (
              <span
                class="inline-flex items-center px-3 py-1.5 text-sm font-medium rounded-lg"
                style="background: rgba(167,139,250,0.12); color: #C4B5FD; border: 1px solid rgba(167,139,250,0.2);"
              >
                {cuisine}
              </span>
            ))}
          </div>
        </section>
      )
    }

    {/* Notes from markdown body */}
    <section
      class="rounded-2xl p-6 sm:p-8 prose-refined"
      style={`background: var(--bg-surface); border: 1px solid var(--border-subtle);`}
    >
      <Content />
    </section>
  </div>
</Layout>

<style>
  .breadcrumb-link:hover {
    color: var(--accent-gold) !important;
  }
  .recipe-link:hover {
    background: var(--bg-hover);
  }
  .recipe-link:hover .recipe-link-name {
    color: var(--accent-gold) !important;
  }
  .recipe-link:hover .recipe-link-arrow {
    color: var(--accent-gold) !important;
  }
</style>
