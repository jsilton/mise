---
// RecipeCard.astro - Reusable recipe card component for grid display
// Encapsulates all card styling, tags, and data attributes

import TagBadge from './TagBadge.astro';
import DietaryBadges from './DietaryBadges.astro';

interface Recipe {
  slug: string;
  data: {
    title: string;
    difficulty?: string;
    role?: string;
    vibe?: string;
    cuisines?: string[];
    dietary?: string[];
    cookingMethods?: string[];
    occasions?: string[];
    flavorProfile?: string[];
    prepTime?: string;
    cookTime?: string;
    ingredients?: string[];
  };
}

interface Props {
  recipe: Recipe;
  baseUrl?: string;
}

const { recipe, baseUrl = import.meta.env.BASE_URL } = Astro.props;

// Extract primary dietary tag (prioritize vegetarian/vegan)
const primaryDietaryTag =
  recipe.data.dietary?.find((d) => d === 'vegetarian' || d === 'vegan') || recipe.data.dietary?.[0];
---

<a
  href={`${baseUrl}recipes/${recipe.slug}`}
  class="recipe-card group rounded-xl shadow-soft hover:shadow-glow transition-all duration-200 overflow-hidden flex flex-col h-full min-h-[15rem]"
  style="background: linear-gradient(to bottom, var(--bg-elevated), var(--bg-surface)); border: 1px solid var(--border-subtle);"
  data-difficulty={recipe.data.difficulty}
  data-role={recipe.data.role}
  data-vibe={recipe.data.vibe}
  data-cuisines={recipe.data.cuisines?.join(',')}
  data-dietary={recipe.data.dietary?.join(',')}
  data-cooking-methods={recipe.data.cookingMethods?.join(',')}
  data-occasions={recipe.data.occasions?.join(',')}
  data-flavor-profile={recipe.data.flavorProfile?.join(',')}
  data-prep-time={recipe.data.prepTime}
>
  <div class="p-4 flex flex-col h-full">
    <h2
      class="text-base font-semibold line-clamp-2 mb-3 leading-snug tracking-tight transition-colors"
      style="color: var(--text-primary);"
    >
      {recipe.data.title}
    </h2>

    <!-- Key Tags -->
    <div class="flex flex-wrap gap-2 mb-3">
      {
        recipe.data.cuisines?.[0] && (
          <TagBadge tag={recipe.data.cuisines[0]} category="cuisine" size="sm" />
        )
      }
      {
        recipe.data.difficulty && (
          <TagBadge tag={recipe.data.difficulty} category="difficulty" size="sm" />
        )
      }
      {primaryDietaryTag && <TagBadge tag={primaryDietaryTag} category="dietary" size="sm" />}
    </div>

    <!-- Dietary badges -->
    {
      recipe.data.dietary && recipe.data.dietary.length > 0 && (
        <div class="mt-3 mb-3">
          <DietaryBadges dietary={recipe.data.dietary} size="sm" />
        </div>
      )
    }

    <!-- Time metadata -->
    <div
      class="mt-auto pt-3 flex items-center justify-between text-xs font-medium"
      style="border-top: 1px solid var(--border-subtle); color: var(--text-tertiary);"
    >
      <div class="flex items-center gap-2">
        {recipe.data.prepTime && <span>{recipe.data.prepTime}</span>}
        {
          recipe.data.cookTime && (
            <span class="flex items-center gap-1">
              <span style="color: var(--border-emphasis);">·</span>
              {recipe.data.cookTime} cook
            </span>
          )
        }
      </div>
    </div>
  </div>

  <!-- Hidden search data for filtering -->
  <div class="hidden search-data">
    {recipe.data.title.toLowerCase()}
    {recipe.data.ingredients?.join(' ').toLowerCase()}
  </div>
</a>

<style>
  .recipe-card:hover {
    border-color: var(--accent-gold-muted) !important;
  }
  .recipe-card:hover h2 {
    color: var(--accent-gold) !important;
  }
</style>
