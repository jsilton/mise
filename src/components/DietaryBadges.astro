---
// DietaryBadges.astro - Prominent dietary callout badges with icons
// Displays dietary tags (vegan, gluten-free, etc.) as colorful pill badges
// Used on recipe cards and headers to highlight key dietary info at a glance

interface Props {
  dietary?: string[];
  size?: 'sm' | 'md';
  className?: string;
}

const { dietary = [], size = 'sm', className = '' } = Astro.props;

// Icon SVGs for each dietary type
const dietaryIcons = {
  'vegan': '<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 16 16"><path d="M8 1a7 7 0 1 0 0 14A7 7 0 0 0 8 1zm2.5 4a.5.5 0 1 1-1 0 .5.5 0 0 1 1 0zm-5 0a.5.5 0 1 1-1 0 .5.5 0 0 1 1 0zm3.5 6c1.5-1 3-1.5 3-2.5 0-.5-1-1-2.5-1s-2.5.5-2.5 1c0 1 1.5 1.5 3 2.5z"/></svg>',
  'vegetarian': '<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 16 16"><path d="M8 1.5a.5.5 0 0 1 .5.5v5.5h5.5a.5.5 0 0 1 0 1h-5.5V14a.5.5 0 0 1-1 0V8.5H1.5a.5.5 0 0 1 0-1H7.5V2a.5.5 0 0 1 .5-.5z"/></svg>',
  'gluten-free': '<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 16 16"><path d="M5.5 2a.5.5 0 0 1 .5.5v2h2V2.5a.5.5 0 0 1 1 0v2h2V2.5a.5.5 0 0 1 1 0v2.5a1.5 1.5 0 0 1-1.5 1.5H8.5v2h2a.5.5 0 0 1 0 1h-2v2a.5.5 0 0 1-1 0v-2h-2v2a.5.5 0 0 1-1 0v-2h-2a.5.5 0 0 1 0-1h2v-2H2.5a.5.5 0 0 1 0-1h2V4.5a.5.5 0 0 1 1.5-1.5H5.5V2z"/></svg>',
  'dairy-free': '<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 16 16"><path d="M8 1a7 7 0 1 0 0 14A7 7 0 0 0 8 1zM4.5 7a1.5 1.5 0 1 1 3 0 1.5 1.5 0 0 1-3 0zm4 0a1.5 1.5 0 1 1 3 0 1.5 1.5 0 0 1-3 0z"/></svg>',
  'nut-free': '<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 16 16"><path d="M8 1a7 7 0 1 1 0 14A7 7 0 0 1 8 1zM4.5 7.5a1 1 0 1 0 2 0 1 1 0 0 0-2 0zm5 0a1 1 0 1 0 2 0 1 1 0 0 0-2 0z"/></svg>',
  'low-carb': '<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 16 16"><path d="M8 1a7 7 0 1 0 0 14A7 7 0 0 0 8 1zm0 2a1 1 0 0 1 1 1v2a1 1 0 0 1-2 0V4a1 1 0 0 1 1-1zm3 2a1 1 0 0 1 1 1v4a1 1 0 0 1-2 0V6a1 1 0 0 1 1-1zm-6 1a1 1 0 0 1 1 1v3a1 1 0 0 1-2 0V7a1 1 0 0 1 1-1z"/></svg>',
  'low-sugar': '<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 16 16"><path d="M8 1a7 7 0 1 0 0 14A7 7 0 0 0 8 1zm0 2.5a1 1 0 0 1 1 1v1a1 1 0 0 1-2 0v-1a1 1 0 0 1 1-1zm0 4a2 2 0 1 1 0 4 2 2 0 0 1 0-4z"/></svg>',
  'keto': '<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 16 16"><path d="M8 1a7 7 0 1 0 0 14A7 7 0 0 0 8 1zm-1 5a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3zm3 0a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3z"/></svg>',
  'high-protein': '<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 16 16"><path d="M8 2a2 2 0 0 1 2 2v1.5h2a1 1 0 0 1 1 1v4a1 1 0 0 1-1 1h-2V12a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-1.5H4a1 1 0 0 1-1-1V6.5a1 1 0 0 1 1-1h2V4a2 2 0 0 1 2-2z"/></svg>',
  'whole30-friendly': '<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 16 16"><path d="M8 1a7 7 0 1 0 0 14A7 7 0 0 0 8 1zm3.5 8.5a1 1 0 1 1-2 0 1 1 0 0 1 2 0zM5.5 10a1 1 0 1 1 0-2 1 1 0 0 1 0 2z"/></svg>',
};

// Color scheme for each dietary tag - distinct, accessible colors
const dietaryColors = {
  'vegan': 'bg-emerald-100 dark:bg-emerald-900 text-emerald-700 dark:text-emerald-200 border-emerald-200 dark:border-emerald-700',
  'vegetarian': 'bg-lime-100 dark:bg-lime-900 text-lime-700 dark:text-lime-200 border-lime-200 dark:border-lime-700',
  'gluten-free': 'bg-blue-100 dark:bg-blue-900 text-blue-700 dark:text-blue-200 border-blue-200 dark:border-blue-700',
  'dairy-free': 'bg-indigo-100 dark:bg-indigo-900 text-indigo-700 dark:text-indigo-200 border-indigo-200 dark:border-indigo-700',
  'nut-free': 'bg-pink-100 dark:bg-pink-900 text-pink-700 dark:text-pink-200 border-pink-200 dark:border-pink-700',
  'low-carb': 'bg-orange-100 dark:bg-orange-900 text-orange-700 dark:text-orange-200 border-orange-200 dark:border-orange-700',
  'low-sugar': 'bg-rose-100 dark:bg-rose-900 text-rose-700 dark:text-rose-200 border-rose-200 dark:border-rose-700',
  'keto': 'bg-amber-100 dark:bg-amber-900 text-amber-700 dark:text-amber-200 border-amber-200 dark:border-amber-700',
  'high-protein': 'bg-red-100 dark:bg-red-900 text-red-700 dark:text-red-200 border-red-200 dark:border-red-700',
  'whole30-friendly': 'bg-teal-100 dark:bg-teal-900 text-teal-700 dark:text-teal-200 border-teal-200 dark:border-teal-700',
};

// Size classes
const sizeClasses = {
  sm: 'px-2 py-0.5 text-2xs gap-1',
  md: 'px-2.5 py-1 text-xs gap-1.5',
};

const sizeClass = sizeClasses[size];

// Filter dietary tags and get colors
const validDietaryTags = dietary.filter(tag => tag in dietaryColors);
---

{
  validDietaryTags.length > 0 && (
    <div class={`flex flex-wrap gap-2 ${className}`}>
      {validDietaryTags.map(tag => (
        <span
          class={`inline-flex items-center font-medium rounded-full border transition-colors hover:opacity-80 ${sizeClass} ${dietaryColors[tag as keyof typeof dietaryColors]}`}
          title={tag.charAt(0).toUpperCase() + tag.slice(1)}
        >
          <Fragment set:html={dietaryIcons[tag as keyof typeof dietaryIcons]} />
          <span>{tag}</span>
        </span>
      ))}
    </div>
  )
}
