---
// DietaryBadges.astro - Prominent dietary callout badges with icons
// Displays dietary tags (vegan, gluten-free, etc.) as colorful pill badges
// Used on recipe cards and headers to highlight key dietary info at a glance

interface Props {
  dietary?: string[];
  size?: 'sm' | 'md';
  className?: string;
}

const { dietary = [], size = 'sm', className = '' } = Astro.props;

// Icon SVGs for each dietary type
const dietaryIcons = {
  vegan:
    '<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 16 16"><path d="M8 1a7 7 0 1 0 0 14A7 7 0 0 0 8 1zm2.5 4a.5.5 0 1 1-1 0 .5.5 0 0 1 1 0zm-5 0a.5.5 0 1 1-1 0 .5.5 0 0 1 1 0zm3.5 6c1.5-1 3-1.5 3-2.5 0-.5-1-1-2.5-1s-2.5.5-2.5 1c0 1 1.5 1.5 3 2.5z"/></svg>',
  vegetarian:
    '<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 16 16"><path d="M8 1.5a.5.5 0 0 1 .5.5v5.5h5.5a.5.5 0 0 1 0 1h-5.5V14a.5.5 0 0 1-1 0V8.5H1.5a.5.5 0 0 1 0-1H7.5V2a.5.5 0 0 1 .5-.5z"/></svg>',
  'gluten-free':
    '<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 16 16"><path d="M5.5 2a.5.5 0 0 1 .5.5v2h2V2.5a.5.5 0 0 1 1 0v2h2V2.5a.5.5 0 0 1 1 0v2.5a1.5 1.5 0 0 1-1.5 1.5H8.5v2h2a.5.5 0 0 1 0 1h-2v2a.5.5 0 0 1-1 0v-2h-2v2a.5.5 0 0 1-1 0v-2h-2a.5.5 0 0 1 0-1h2v-2H2.5a.5.5 0 0 1 0-1h2V4.5a.5.5 0 0 1 1.5-1.5H5.5V2z"/></svg>',
  'dairy-free':
    '<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 16 16"><path d="M8 1a7 7 0 1 0 0 14A7 7 0 0 0 8 1zM4.5 7a1.5 1.5 0 1 1 3 0 1.5 1.5 0 0 1-3 0zm4 0a1.5 1.5 0 1 1 3 0 1.5 1.5 0 0 1-3 0z"/></svg>',
  'nut-free':
    '<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 16 16"><path d="M8 1a7 7 0 1 1 0 14A7 7 0 0 1 8 1zM4.5 7.5a1 1 0 1 0 2 0 1 1 0 0 0-2 0zm5 0a1 1 0 1 0 2 0 1 1 0 0 0-2 0z"/></svg>',
  'low-carb':
    '<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 16 16"><path d="M8 1a7 7 0 1 0 0 14A7 7 0 0 0 8 1zm0 2a1 1 0 0 1 1 1v2a1 1 0 0 1-2 0V4a1 1 0 0 1 1-1zm3 2a1 1 0 0 1 1 1v4a1 1 0 0 1-2 0V6a1 1 0 0 1 1-1zm-6 1a1 1 0 0 1 1 1v3a1 1 0 0 1-2 0V7a1 1 0 0 1 1-1z"/></svg>',
  'low-sugar':
    '<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 16 16"><path d="M8 1a7 7 0 1 0 0 14A7 7 0 0 0 8 1zm0 2.5a1 1 0 0 1 1 1v1a1 1 0 0 1-2 0v-1a1 1 0 0 1 1-1zm0 4a2 2 0 1 1 0 4 2 2 0 0 1 0-4z"/></svg>',
  keto: '<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 16 16"><path d="M8 1a7 7 0 1 0 0 14A7 7 0 0 0 8 1zm-1 5a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3zm3 0a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3z"/></svg>',
  'high-protein':
    '<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 16 16"><path d="M8 2a2 2 0 0 1 2 2v1.5h2a1 1 0 0 1 1 1v4a1 1 0 0 1-1 1h-2V12a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-1.5H4a1 1 0 0 1-1-1V6.5a1 1 0 0 1 1-1h2V4a2 2 0 0 1 2-2z"/></svg>',
  'whole30-friendly':
    '<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 16 16"><path d="M8 1a7 7 0 1 0 0 14A7 7 0 0 0 8 1zm3.5 8.5a1 1 0 1 1-2 0 1 1 0 0 1 2 0zM5.5 10a1 1 0 1 1 0-2 1 1 0 0 1 0 2z"/></svg>',
};

// Map dietary tag to CSS class name
const dietaryClassMap: Record<string, string> = {
  vegan: 'dietary-vegan',
  vegetarian: 'dietary-vegetarian',
  'gluten-free': 'dietary-gluten-free',
  'dairy-free': 'dietary-dairy-free',
  'nut-free': 'dietary-nut-free',
  'low-carb': 'dietary-low-carb',
  'low-sugar': 'dietary-low-sugar',
  keto: 'dietary-keto',
  'high-protein': 'dietary-high-protein',
  'whole30-friendly': 'dietary-whole30-friendly',
};

// Size classes
const sizeClasses = {
  sm: 'px-2.5 py-1 text-xs gap-1.5',
  md: 'px-3 py-1.5 text-sm gap-2',
};

const sizeClass = sizeClasses[size];

// Filter dietary tags and get colors
const validDietaryTags = dietary.filter((tag) => tag in dietaryClassMap);
---

{
  validDietaryTags.length > 0 && (
    <div class={`flex flex-wrap gap-2 ${className}`}>
      {validDietaryTags.map((tag) => (
        <span
          class={`inline-flex items-center font-medium rounded-full border transition-colors hover:opacity-80 ${sizeClass} ${dietaryClassMap[tag]}`}
          title={tag.charAt(0).toUpperCase() + tag.slice(1)}
        >
          <Fragment set:html={dietaryIcons[tag as keyof typeof dietaryIcons]} />
          <span>{tag}</span>
        </span>
      ))}
    </div>
  )
}

<style>
  .dietary-vegan {
    background-color: rgba(16, 185, 129, 0.12);
    color: #6ee7b7;
    border-color: rgba(16, 185, 129, 0.2);
  }

  .dietary-vegetarian {
    background-color: rgba(132, 204, 22, 0.12);
    color: #bef264;
    border-color: rgba(132, 204, 22, 0.2);
  }

  .dietary-gluten-free {
    background-color: rgba(59, 130, 246, 0.12);
    color: #93c5fd;
    border-color: rgba(59, 130, 246, 0.2);
  }

  .dietary-dairy-free {
    background-color: rgba(99, 102, 241, 0.12);
    color: #a5b4fc;
    border-color: rgba(99, 102, 241, 0.2);
  }

  .dietary-nut-free {
    background-color: rgba(236, 72, 153, 0.12);
    color: #f9a8d4;
    border-color: rgba(236, 72, 153, 0.2);
  }

  .dietary-low-carb {
    background-color: rgba(249, 115, 22, 0.12);
    color: #fdba74;
    border-color: rgba(249, 115, 22, 0.2);
  }

  .dietary-low-sugar {
    background-color: rgba(244, 63, 94, 0.12);
    color: #fda4af;
    border-color: rgba(244, 63, 94, 0.2);
  }

  .dietary-keto {
    background-color: rgba(245, 158, 11, 0.12);
    color: #fcd34d;
    border-color: rgba(245, 158, 11, 0.2);
  }

  .dietary-high-protein {
    background-color: rgba(239, 68, 68, 0.12);
    color: #fca5a5;
    border-color: rgba(239, 68, 68, 0.2);
  }

  .dietary-whole30-friendly {
    background-color: rgba(20, 184, 166, 0.12);
    color: #5eead4;
    border-color: rgba(20, 184, 166, 0.2);
  }
</style>
