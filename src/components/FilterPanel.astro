---
// FilterPanel.astro - Complete filter and sort UI component
// Includes filter dropdowns, sort options, reset button, and filtering logic
// Self-contained: manages all data, rendering, and client-side interactivity

interface Props {
  recipes: Array<{
    data: {
      difficulty?: string;
      role?: string;
      vibe?: string;
      cuisines?: string[];
      dietary?: string[];
      cookingMethods?: string[];
      occasions?: string[];
      flavorProfile?: string[];
      seasons?: string[];
    };
  }>;
}

const { recipes = [] } = Astro.props;

// Collect all unique values for each filter dimension
const uniqueFilters = {
  roles: Array.from(
    new Set(recipes.map((r) => r.data.role).filter((r): r is string => Boolean(r)))
  ).sort(),
  vibes: Array.from(
    new Set(recipes.map((r) => r.data.vibe).filter((v): v is string => Boolean(v)))
  ).sort(),
  cuisines: Array.from(new Set(recipes.flatMap((r) => r.data.cuisines || []))).sort(),
  dietary: Array.from(new Set(recipes.flatMap((r) => r.data.dietary || []))).sort(),
  cookingMethods: Array.from(new Set(recipes.flatMap((r) => r.data.cookingMethods || []))).sort(),
  occasions: Array.from(new Set(recipes.flatMap((r) => r.data.occasions || []))).sort(),
  flavorProfiles: Array.from(new Set(recipes.flatMap((r) => r.data.flavorProfile || []))).sort(),
  seasons: Array.from(new Set(recipes.flatMap((r) => r.data.seasons || []))).sort(),
};

// Format values for display (capitalize)
const formatLabel = (val: string) => val.charAt(0).toUpperCase() + val.slice(1).replace(/-/g, ' ');
---

<div
  class="mb-8 p-4 rounded-xl shadow-soft"
  style="background: var(--bg-surface); border: 1px solid var(--border-subtle);"
>
  <div class="flex flex-col gap-4">
    <!-- Header with reset button -->
    <div class="flex items-center justify-between">
      <h3
        class="text-xs font-semibold uppercase tracking-wide"
        style="color: var(--text-tertiary);"
      >
        Filters & Sort
      </h3>
      <button
        id="resetFilters"
        class="text-xs font-medium transition-colors"
        style="color: var(--accent-gold);"
        onmouseover="this.style.color='var(--accent-gold-bright)'"
        onmouseout="this.style.color='var(--accent-gold)'"
      >
        Reset
      </button>
    </div>

    <!-- Filter Controls Grid -->
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-9 gap-3">
      <!-- Difficulty Filter -->
      <div class="flex flex-col gap-1.5">
        <label
          for="filterDifficulty"
          class="text-2xs font-medium uppercase tracking-wide"
          style="color: var(--text-tertiary);">Difficulty</label
        >
        <select
          id="filterDifficulty"
          class="filter-select text-xs rounded-lg px-2.5 py-2 transition-all"
        >
          <option value="">All</option>
          <option value="easy">Easy</option>
          <option value="intermediate">Intermediate</option>
          <option value="advanced">Advanced</option>
        </select>
      </div>

      <!-- Role Filter -->
      <div class="flex flex-col gap-1.5">
        <label
          for="filterRole"
          class="text-2xs font-medium uppercase tracking-wide"
          style="color: var(--text-tertiary);">Role</label
        >
        <select id="filterRole" class="filter-select text-xs rounded-lg px-2.5 py-2 transition-all">
          <option value="">All</option>
          {uniqueFilters.roles.map((r) => <option value={r}>{formatLabel(r)}</option>)}
        </select>
      </div>

      <!-- Vibe Filter -->
      <div class="flex flex-col gap-1.5">
        <label
          for="filterVibe"
          class="text-2xs font-medium uppercase tracking-wide"
          style="color: var(--text-tertiary);">Vibe</label
        >
        <select id="filterVibe" class="filter-select text-xs rounded-lg px-2.5 py-2 transition-all">
          <option value="">All</option>
          {uniqueFilters.vibes.map((v) => <option value={v}>{formatLabel(v)}</option>)}
        </select>
      </div>

      <!-- Cuisine Filter -->
      <div class="flex flex-col gap-1.5">
        <label
          for="filterCuisine"
          class="text-2xs font-medium uppercase tracking-wide"
          style="color: var(--text-tertiary);">Cuisine</label
        >
        <select
          id="filterCuisine"
          class="filter-select text-xs rounded-lg px-2.5 py-2 transition-all"
        >
          <option value="">All</option>
          {uniqueFilters.cuisines.map((c) => <option value={c}>{formatLabel(c)}</option>)}
        </select>
      </div>

      <!-- Dietary Filter -->
      <div class="flex flex-col gap-1.5">
        <label
          for="filterDietary"
          class="text-2xs font-medium uppercase tracking-wide"
          style="color: var(--text-tertiary);">Dietary</label
        >
        <select
          id="filterDietary"
          class="filter-select text-xs rounded-lg px-2.5 py-2 transition-all"
        >
          <option value="">All</option>
          {uniqueFilters.dietary.map((d) => <option value={d}>{formatLabel(d)}</option>)}
        </select>
      </div>

      <!-- Cooking Method Filter -->
      <div class="flex flex-col gap-1.5">
        <label
          for="filterCookingMethod"
          class="text-2xs font-medium uppercase tracking-wide"
          style="color: var(--text-tertiary);">Method</label
        >
        <select
          id="filterCookingMethod"
          class="filter-select text-xs rounded-lg px-2.5 py-2 transition-all"
        >
          <option value="">All</option>
          {uniqueFilters.cookingMethods.map((m) => <option value={m}>{formatLabel(m)}</option>)}
        </select>
      </div>

      <!-- Occasion Filter -->
      <div class="flex flex-col gap-1.5">
        <label
          for="filterOccasion"
          class="text-2xs font-medium uppercase tracking-wide"
          style="color: var(--text-tertiary);">Occasion</label
        >
        <select
          id="filterOccasion"
          class="filter-select text-xs rounded-lg px-2.5 py-2 transition-all"
        >
          <option value="">All</option>
          {uniqueFilters.occasions.map((o) => <option value={o}>{formatLabel(o)}</option>)}
        </select>
      </div>

      <!-- Flavor Profile Filter -->
      <div class="flex flex-col gap-1.5">
        <label
          for="filterFlavor"
          class="text-2xs font-medium uppercase tracking-wide"
          style="color: var(--text-tertiary);">Flavor</label
        >
        <select
          id="filterFlavor"
          class="filter-select text-xs rounded-lg px-2.5 py-2 transition-all"
        >
          <option value="">All</option>
          {uniqueFilters.flavorProfiles.map((f) => <option value={f}>{formatLabel(f)}</option>)}
        </select>
      </div>

      <!-- Sort By -->
      <div class="flex flex-col gap-1.5">
        <label
          for="sortBy"
          class="text-2xs font-medium uppercase tracking-wide"
          style="color: var(--text-tertiary);">Sort By</label
        >
        <select id="sortBy" class="filter-select text-xs rounded-lg px-2.5 py-2 transition-all">
          <option value="title">Alphabetical</option>
          <option value="prepTime">Prep Time</option>
          <option value="difficulty">Difficulty</option>
        </select>
      </div>
    </div>
  </div>
</div>

<style>
  .filter-select {
    background-color: var(--bg-elevated);
    color: var(--text-primary);
    border: 1px solid var(--border-subtle);
  }
  .filter-select:focus {
    outline: none;
    box-shadow: 0 0 0 2px rgba(201, 169, 97, 0.3);
    border-color: var(--accent-gold-muted);
  }
  .filter-select option {
    background-color: var(--bg-elevated);
    color: var(--text-primary);
  }
</style>

<script>
  // Expose filter state and filtering function to parent scope
  window.filterState = {
    difficulty: '',
    role: '',
    vibe: '',
    cuisine: '',
    dietary: '',
    cookingMethod: '',
    occasion: '',
    flavor: '',
    sortMode: 'title',
  };

  window.updateFilterState = function () {
    window.filterState.difficulty = document.getElementById('filterDifficulty').value;
    window.filterState.role = document.getElementById('filterRole').value;
    window.filterState.vibe = document.getElementById('filterVibe').value;
    window.filterState.cuisine = document.getElementById('filterCuisine').value;
    window.filterState.dietary = document.getElementById('filterDietary').value;
    window.filterState.cookingMethod = document.getElementById('filterCookingMethod').value;
    window.filterState.occasion = document.getElementById('filterOccasion').value;
    window.filterState.flavor = document.getElementById('filterFlavor').value;
    window.filterState.sortMode = document.getElementById('sortBy').value;
  };

  // Handler for filter/sort changes
  const handleFilterChange = () => {
    window.updateFilterState();
    window.applyFiltersAndSort?.();
  };

  // Reset all filters to default values
  const resetAllFilters = () => {
    document.getElementById('filterDifficulty').value = '';
    document.getElementById('filterRole').value = '';
    document.getElementById('filterVibe').value = '';
    document.getElementById('filterCuisine').value = '';
    document.getElementById('filterDietary').value = '';
    document.getElementById('filterCookingMethod').value = '';
    document.getElementById('filterOccasion').value = '';
    document.getElementById('filterFlavor').value = '';
    document.getElementById('sortBy').value = 'title';
    handleFilterChange();
  };

  // Attach event listeners
  const filterIds = [
    'filterDifficulty',
    'filterRole',
    'filterVibe',
    'filterCuisine',
    'filterDietary',
    'filterCookingMethod',
    'filterOccasion',
    'filterFlavor',
    'sortBy',
  ];

  filterIds.forEach((id) => {
    document.getElementById(id)?.addEventListener('change', handleFilterChange);
  });

  document.getElementById('resetFilters')?.addEventListener('click', resetAllFilters);
</script>
