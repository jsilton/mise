---
// TagBadge.astro - Reusable tag badge component for consistent styling across pages

interface Props {
  tag: string;
  category:
    | 'cooking-method'
    | 'cuisine'
    | 'dietary'
    | 'occasion'
    | 'flavor'
    | 'difficulty'
    | 'role'
    | 'vibe';
  href?: string;
  size?: 'sm' | 'md' | 'lg';
}

const { tag, category, href, size = 'md' } = Astro.props;

// Map category to CSS class name
const categoryClassMap: Record<string, string> = {
  'cooking-method': 'tag-cooking-method',
  cuisine: 'tag-cuisine',
  dietary: 'tag-dietary',
  occasion: 'tag-occasion',
  flavor: 'tag-flavor',
  difficulty: 'tag-difficulty',
  role: 'tag-role',
  vibe: 'tag-vibe',
};

const sizeClasses = {
  sm: 'px-2.5 py-0.5 text-xs gap-1',
  md: 'px-3 py-1 text-sm gap-1.5',
  lg: 'text-sm px-3 py-1.5 font-medium',
};

const colorClass = categoryClassMap[category] || 'tag-difficulty';
const sizeClass = sizeClasses[size];
---

{
  href ? (
    <a
      href={href}
      class={`inline-flex items-center gap-1 border rounded-full font-medium transition-colors ${colorClass} ${sizeClass}`}
    >
      {tag}
    </a>
  ) : (
    <span
      class={`inline-flex items-center gap-1 border rounded-full font-medium ${colorClass} ${sizeClass}`}
    >
      {tag}
    </span>
  )
}

<style>
  .tag-cooking-method {
    background-color: rgba(96, 165, 250, 0.12);
    color: #93c5fd;
    border-color: rgba(96, 165, 250, 0.2);
  }
  .tag-cooking-method:hover {
    background-color: rgba(96, 165, 250, 0.18);
  }

  .tag-cuisine {
    background-color: rgba(139, 92, 246, 0.12);
    color: #b49ae8;
    border-color: rgba(139, 92, 246, 0.2);
  }
  .tag-cuisine:hover {
    background-color: rgba(139, 92, 246, 0.18);
  }

  .tag-dietary {
    background-color: rgba(52, 211, 153, 0.12);
    color: #6ee7b7;
    border-color: rgba(52, 211, 153, 0.2);
  }
  .tag-dietary:hover {
    background-color: rgba(52, 211, 153, 0.18);
  }

  .tag-occasion {
    background-color: rgba(251, 191, 36, 0.12);
    color: #fcd34d;
    border-color: rgba(251, 191, 36, 0.2);
  }
  .tag-occasion:hover {
    background-color: rgba(251, 191, 36, 0.18);
  }

  .tag-flavor {
    background-color: rgba(251, 113, 133, 0.12);
    color: #fda4af;
    border-color: rgba(251, 113, 133, 0.2);
  }
  .tag-flavor:hover {
    background-color: rgba(251, 113, 133, 0.18);
  }

  .tag-difficulty {
    background-color: rgba(201, 169, 97, 0.12);
    color: #c9a961;
    border-color: rgba(201, 169, 97, 0.2);
  }
  .tag-difficulty:hover {
    background-color: rgba(201, 169, 97, 0.18);
  }

  .tag-role {
    background-color: rgba(123, 142, 184, 0.12);
    color: #9aadcf;
    border-color: rgba(123, 142, 184, 0.2);
  }
  .tag-role:hover {
    background-color: rgba(123, 142, 184, 0.18);
  }

  .tag-vibe {
    background-color: rgba(45, 212, 191, 0.12);
    color: #5eead4;
    border-color: rgba(45, 212, 191, 0.2);
  }
  .tag-vibe:hover {
    background-color: rgba(45, 212, 191, 0.18);
  }
</style>
