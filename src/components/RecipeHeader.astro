---
// RecipeHeader.astro - Recipe detail header with breadcrumb, title, metadata, and tags
// Self-contained logical unit for recipe pages

import TagSection from './TagSection.astro';
import TagBadge from './TagBadge.astro';
import DietaryBadges from './DietaryBadges.astro';

interface Recipe {
  slug: string;
  data: {
    title: string;
    prepTime?: string;
    cookTime?: string;
    totalTime?: string;
    servings?: string;
    difficulty?: string;
    role?: string;
    vibe?: string;
    cuisines?: string[];
    cookingMethods?: string[];
    dietary?: string[];
    occasions?: string[];
    flavorProfile?: string[];
  };
}

interface Props {
  recipe: Recipe;
  baseUrl?: string;
}

const { recipe, baseUrl = import.meta.env.BASE_URL } = Astro.props;
---

<div class="flex flex-col gap-6" data-recipe-header>
  <!-- Cook Mode Toggle -->
  <div class="flex justify-end">
    <button
      id="cook-mode-toggle"
      class="px-4 py-2 text-sm font-medium rounded-lg transition-all duration-200 active:scale-95"
      style="background: var(--accent-gold); color: var(--bg-deep);"
      title="Toggle Cook Mode (Press 'c')"
    >
      Cook Mode
    </button>
  </div>

  <!-- Breadcrumbs -->
  <nav class="flex text-sm" style="color: var(--text-tertiary);" aria-label="Breadcrumb">
    <ol class="inline-flex items-center space-x-1 md:space-x-2">
      <li class="inline-flex items-center">
        <a
          href={baseUrl}
          class="inline-flex items-center font-medium transition-colors"
          style="color: var(--text-tertiary);"
          onmouseover="this.style.color='var(--accent-gold)'"
          onmouseout="this.style.color='var(--text-tertiary)'"
        >
          Codex
        </a>
      </li>
      <li>
        <div class="flex items-center">
          <svg
            class="w-3 h-3 mx-1.5"
            style="color: var(--border-emphasis);"
            aria-hidden="true"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 6 10"
          >
            <path
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="m1 9 4-4-4-4"></path>
          </svg>
          <span
            class="ml-1 font-medium truncate max-w-[200px] sm:max-w-none"
            style="color: var(--text-secondary);"
          >
            {recipe.data.title}
          </span>
        </div>
      </li>
    </ol>
  </nav>

  <!-- Header Section -->
  <div
    class="rounded-2xl shadow-soft overflow-hidden"
    style="background: var(--bg-surface); border: 1px solid var(--border-subtle);"
  >
    <!-- Title and Metadata -->
    <div
      class="p-6 sm:p-8"
      style="background: linear-gradient(to bottom, var(--bg-elevated), var(--bg-surface)); border-bottom: 1px solid var(--border-subtle);"
    >
      <h1
        class="text-2xl sm:text-3xl font-display font-semibold mb-4 tracking-tight leading-tight"
        style="color: var(--text-primary);"
      >
        {recipe.data.title}
      </h1>

      <!-- Dietary Badges -->
      {
        recipe.data.dietary && recipe.data.dietary.length > 0 && (
          <div class="mb-6">
            <DietaryBadges dietary={recipe.data.dietary} size="md" />
          </div>
        )
      }

      <!-- Time Metadata Grid -->
      <div class="flex flex-wrap gap-8 text-sm mb-8">
        {
          recipe.data.prepTime && (
            <div class="flex flex-col">
              <span
                class="text-xs uppercase tracking-wide font-semibold mb-1"
                style="color: var(--text-tertiary);"
              >
                Prep Time
              </span>
              <span class="font-semibold" style="color: var(--text-secondary);">
                {recipe.data.prepTime}
              </span>
            </div>
          )
        }
        {
          recipe.data.cookTime && (
            <div class="flex flex-col">
              <span
                class="text-xs uppercase tracking-wide font-semibold mb-1"
                style="color: var(--text-tertiary);"
              >
                Cook Time
              </span>
              <span class="font-semibold" style="color: var(--text-secondary);">
                {recipe.data.cookTime}
              </span>
            </div>
          )
        }
        {
          recipe.data.totalTime && (
            <div class="flex flex-col">
              <span
                class="text-xs uppercase tracking-wide font-semibold mb-1"
                style="color: var(--text-tertiary);"
              >
                Total Time
              </span>
              <span class="font-semibold" style="color: var(--text-secondary);">
                {recipe.data.totalTime}
              </span>
            </div>
          )
        }
        {
          recipe.data.servings && (
            <div class="flex flex-col">
              <span
                class="text-2xs uppercase tracking-wide font-semibold mb-1"
                style="color: var(--text-tertiary);"
              >
                Servings
              </span>
              <span class="font-semibold" style="color: var(--text-secondary);">
                {recipe.data.servings}
              </span>
            </div>
          )
        }
      </div>

      <!-- Tags Section -->
      <div class="pt-6" style="border-top: 1px solid var(--border-subtle);">
        {/* Primary Metadata - Role, Vibe, Difficulty */}
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
          {
            recipe.data.role && (
              <div>
                <h4
                  class="text-xs uppercase tracking-wide font-semibold mb-2"
                  style="color: var(--text-tertiary);"
                >
                  Role
                </h4>
                <TagBadge
                  tag={recipe.data.role}
                  category="role"
                  size="md"
                  href={`${baseUrl}?role=${recipe.data.role}`}
                />
              </div>
            )
          }
          {
            recipe.data.vibe && (
              <div>
                <h4
                  class="text-xs uppercase tracking-wide font-semibold mb-2"
                  style="color: var(--text-tertiary);"
                >
                  Vibe
                </h4>
                <TagBadge
                  tag={recipe.data.vibe}
                  category="vibe"
                  size="md"
                  href={`${baseUrl}?vibe=${recipe.data.vibe}`}
                />
              </div>
            )
          }
          {
            recipe.data.difficulty && (
              <div>
                <h4
                  class="text-xs uppercase tracking-wide font-semibold mb-2"
                  style="color: var(--text-tertiary);"
                >
                  Difficulty
                </h4>
                <TagBadge
                  tag={recipe.data.difficulty}
                  category="difficulty"
                  size="md"
                  href={`${baseUrl}?difficulty=${recipe.data.difficulty}`}
                />
              </div>
            )
          }
        </div>

        {/* Secondary Metadata - Cuisines and Methods */}
        <div class="space-y-4">
          {
            recipe.data.cuisines && recipe.data.cuisines.length > 0 && (
              <TagSection
                title="Cuisines"
                tags={recipe.data.cuisines}
                category="cuisine"
                size="sm"
                baseUrl={baseUrl}
              />
            )
          }
          {
            recipe.data.cookingMethods && recipe.data.cookingMethods.length > 0 && (
              <TagSection
                title="Cooking Methods"
                tags={recipe.data.cookingMethods}
                category="cooking-method"
                size="sm"
                baseUrl={baseUrl}
              />
            )
          }
          {
            recipe.data.flavorProfile && recipe.data.flavorProfile.length > 0 && (
              <TagSection
                title="Flavor Profile"
                tags={recipe.data.flavorProfile}
                category="flavor"
                size="sm"
                baseUrl={baseUrl}
              />
            )
          }
          {
            recipe.data.dietary && recipe.data.dietary.length > 0 && (
              <TagSection
                title="Dietary"
                tags={recipe.data.dietary}
                category="dietary"
                size="sm"
                baseUrl={baseUrl}
              />
            )
          }
          {
            recipe.data.occasions && recipe.data.occasions.length > 0 && (
              <TagSection
                title="Occasions"
                tags={recipe.data.occasions}
                category="occasion"
                size="sm"
                baseUrl={baseUrl}
              />
            )
          }
        </div>
      </div>
    </div>
  </div>
</div>
