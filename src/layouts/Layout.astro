---
interface Props {
  title: string;
  jsonLd?: string;
}

const { title, jsonLd } = Astro.props;
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="The Recipe Collection" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <link rel="stylesheet" href={`${import.meta.env.BASE_URL}styles/print.css`} media="print" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <!-- eslint-disable-next-line astro/no-set-html-directive -->
    {jsonLd && <script type="application/ld+json" set:html={jsonLd} />}
    <style is:global>
      /* ═══════════════════════════════════════════════════════
       * MISE DESIGN SYSTEM — Dark-Mode-First
       * Japanese-inspired warm dark palette
       * 
       * Color Tokens:
       *   --bg-deep:      #0C0C0E  (page background)
       *   --bg-surface:   #141416  (card/panel)
       *   --bg-elevated:  #1A1A1E  (elevated cards)
       *   --bg-hover:     #222226  (hover state)
       *   --border-subtle:   #2A2A2E
       *   --border-emphasis: #3A3A3E
       *   --text-primary:   #F0EDE6  (warm off-white)
       *   --text-secondary: #9A9690  (muted)
       *   --text-tertiary:  #5A5854  (hint)
       *   --accent-gold:       #C9A961
       *   --accent-gold-muted: #8B7A4A
       *   --accent-gold-bright:#DFC07C
       *   --accent-link:       #7B8EB8  (links)
       *   --accent-link-bright:#9AADCF  (link hover)
       * ═══════════════════════════════════════════════════════ */

      :root {
        --bg-deep: #0c0c0e;
        --bg-surface: #141416;
        --bg-elevated: #1a1a1e;
        --bg-hover: #222226;
        --border-subtle: #2a2a2e;
        --border-emphasis: #3a3a3e;
        --text-primary: #f0ede6;
        --text-secondary: #9a9690;
        --text-tertiary: #5a5854;
        --accent-gold: #c9a961;
        --accent-gold-muted: #8b7a4a;
        --accent-gold-bright: #dfc07c;
        --accent-link: #7b8eb8;
        --accent-link-bright: #9aadcf;
      }

      /* ───────────────────────────────────
       * Typography System — Prose Refined
       * Cormorant Garamond headings + Inter body
       * ─────────────────────────────────── */

      /* Headings - Clear hierarchy with serif display */
      .prose-refined h2 {
        font-family: 'Cormorant Garamond', Georgia, serif;
        font-size: 1.5rem;
        font-weight: 700;
        letter-spacing: -0.02em;
        color: var(--text-primary);
        margin-top: 2.5rem;
        margin-bottom: 1rem;
        padding-bottom: 0.625rem;
        border-bottom: 1px solid var(--border-subtle);
        line-height: 1.3;
      }
      .prose-refined h2:first-child {
        margin-top: 0;
      }

      .prose-refined h3 {
        font-size: 1.0625rem;
        font-weight: 600;
        color: var(--text-primary);
        margin-top: 2rem;
        margin-bottom: 0.75rem;
        line-height: 1.3;
      }

      /* Paragraphs */
      .prose-refined p {
        font-size: 0.9375rem;
        color: var(--text-secondary);
        line-height: 1.65;
        margin-bottom: 1.25em;
      }

      /* Category headers (paragraphs containing only a strong tag) */
      .prose-refined p > strong:only-child {
        display: block;
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-top: 1.5rem;
        margin-bottom: 0.25rem;
        padding-bottom: 0;
      }
      .prose-refined p:has(> strong:only-child) {
        margin-bottom: 0.5rem;
      }

      /* Strong and emphasis */
      .prose-refined strong {
        font-weight: 500;
        color: var(--text-primary);
      }
      .prose-refined em {
        font-style: italic;
        color: var(--text-secondary);
      }

      /* Unordered lists */
      .prose-refined ul {
        list-style: none;
        padding-left: 0;
        margin-top: 0.5rem;
        margin-bottom: 1.5rem;
      }
      .prose-refined ul li {
        position: relative;
        padding-left: 1.25rem;
        font-size: 0.9375rem;
        color: var(--text-secondary);
        line-height: 1.6;
        margin-bottom: 0.375rem;
      }
      .prose-refined ul li::before {
        content: '•';
        position: absolute;
        left: 0;
        color: var(--text-tertiary);
        font-weight: 600;
      }
      .prose-refined ul li a {
        font-weight: 600;
      }
      .prose-refined ul li em {
        color: var(--text-tertiary);
        font-style: normal;
        font-size: 0.875rem;
      }

      /* Ordered lists (recipe directions) */
      .prose-refined ol {
        list-style: none;
        padding-left: 0;
        margin-top: 0.75rem;
        margin-bottom: 1.5rem;
        counter-reset: step-counter;
      }
      .prose-refined ol li {
        position: relative;
        padding-left: 2rem;
        font-size: 0.9375rem;
        color: var(--text-secondary);
        line-height: 1.65;
        margin-bottom: 0.75rem;
        counter-increment: step-counter;
      }
      .prose-refined ol li::before {
        content: counter(step-counter) '.';
        position: absolute;
        left: 0;
        top: 0;
        font-size: 0.875rem;
        font-weight: 700;
        color: var(--accent-gold);
        width: 1.5rem;
      }
      .prose-refined ol li strong:first-child {
        font-weight: 600;
        color: var(--text-primary);
      }

      /* Links */
      .prose-refined a {
        color: var(--accent-link);
        text-decoration: none;
        font-weight: 500;
        transition: color 0.15s ease;
      }
      .prose-refined a:hover {
        color: var(--accent-link-bright);
        text-decoration: underline;
        text-underline-offset: 2px;
      }

      /* Tables */
      .prose-refined table {
        width: 100%;
        margin: 1.5rem 0;
        font-size: 0.875rem;
        border-radius: 0.5rem;
        overflow: hidden;
        background: var(--bg-elevated);
        border: 1px solid var(--border-subtle);
      }
      .prose-refined thead {
        background: var(--bg-deep);
      }
      .prose-refined thead tr {
        border-bottom: 1px solid var(--border-subtle);
      }
      .prose-refined th {
        padding: 0.75rem 1rem;
        text-align: left;
        font-size: 0.6875rem;
        font-weight: 700;
        color: var(--text-tertiary);
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }
      .prose-refined td {
        padding: 0.625rem 1rem;
        color: var(--text-secondary);
        background: var(--bg-surface);
        border-bottom: 1px solid var(--border-subtle);
        line-height: 1.5;
      }
      .prose-refined tbody tr:last-child td {
        border-bottom: none;
      }
      .prose-refined td:first-child {
        font-weight: 600;
        color: var(--text-primary);
        white-space: nowrap;
      }

      /* Horizontal rule */
      .prose-refined hr {
        border: none;
        height: 1px;
        background: linear-gradient(to right, transparent, var(--border-emphasis), transparent);
        margin: 2.5rem 0;
      }

      /* Block quotes */
      .prose-refined blockquote {
        margin: 1.5rem 0;
        padding: 1rem 1.25rem;
        background: rgba(201, 169, 97, 0.06);
        border-left: 3px solid var(--accent-gold-muted);
        border-radius: 0 0.375rem 0.375rem 0;
      }
      .prose-refined blockquote p {
        margin-bottom: 0;
        font-size: 0.875rem;
        color: var(--accent-gold-bright);
      }

      /* Code inline */
      .prose-refined code {
        font-size: 0.875em;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        background: var(--bg-elevated);
        padding: 0.125rem 0.375rem;
        border-radius: 0.25rem;
        color: var(--text-secondary);
      }
    </style>
  </head>
  <body
    class="h-full flex flex-col font-sans antialiased"
    style="background-color: var(--bg-deep); color: var(--text-primary);"
  >
    <header
      style="background-color: rgba(12, 12, 14, 0.85); border-bottom: 1px solid var(--border-subtle);"
      class="backdrop-blur-md sticky top-0 z-20"
    >
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-14 flex items-center justify-between">
        <div class="flex items-center gap-4">
          <a href={import.meta.env.BASE_URL} class="flex items-center gap-2.5 group">
            <div
              class="w-7 h-7 rounded-lg flex items-center justify-center text-sm shadow-sm transition-all duration-200"
              style="background: linear-gradient(135deg, var(--accent-gold), var(--accent-gold-muted)); color: var(--bg-deep); font-weight: 700;"
            >
              M
            </div>
            <span
              class="text-lg font-bold tracking-tight transition-colors"
              style="color: var(--text-primary);">Mise</span
            >
          </a>
        </div>

        <nav class="flex items-center gap-1">
          <a
            href={import.meta.env.BASE_URL}
            class="px-3 py-1.5 text-sm font-medium rounded-lg transition-colors"
            style="color: var(--text-secondary);"
            onmouseover="this.style.color='var(--text-primary)';this.style.backgroundColor='var(--bg-hover)'"
            onmouseout="this.style.color='var(--text-secondary)';this.style.backgroundColor='transparent'"
            >Recipes</a
          >
          <a
            href={`${import.meta.env.BASE_URL}meals`}
            class="px-3 py-1.5 text-sm font-medium rounded-lg transition-colors"
            style="color: var(--text-secondary);"
            onmouseover="this.style.color='var(--text-primary)';this.style.backgroundColor='var(--bg-hover)'"
            onmouseout="this.style.color='var(--text-secondary)';this.style.backgroundColor='transparent'"
            >Meals</a
          >
          <a
            href={`${import.meta.env.BASE_URL}calendar`}
            class="px-3 py-1.5 text-sm font-medium rounded-lg transition-colors"
            style="color: var(--text-secondary);"
            onmouseover="this.style.color='var(--text-primary)';this.style.backgroundColor='var(--bg-hover)'"
            onmouseout="this.style.color='var(--text-secondary)';this.style.backgroundColor='transparent'"
            >Calendar</a
          >
        </nav>
      </div>
    </header>

    <main class="flex-grow w-full max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <slot />
    </main>

    <footer
      style="border-top: 1px solid var(--border-subtle); background-color: rgba(12, 12, 14, 0.5);"
      class="mt-auto"
    >
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
        <div class="flex flex-col md:flex-row justify-between items-center gap-3">
          <p class="text-xs" style="color: var(--text-tertiary);">
            &copy; {new Date().getFullYear()} Mise. All rights reserved.
          </p>
          <div class="flex gap-2 text-xs" style="color: var(--text-tertiary);">
            <span>Taste</span>
            <span style="color: var(--border-emphasis);">·</span>
            <span>Tradition</span>
            <span style="color: var(--border-emphasis);">·</span>
            <span>Together</span>
          </div>
        </div>
      </div>
    </footer>

    <script>
      // Keyboard shortcuts
      document.addEventListener('keydown', (e) => {
        // Forward slash or Cmd+K to focus search
        if ((e.key === '/' || (e.metaKey && e.key === 'k')) && !e.ctrlKey) {
          e.preventDefault();
          const searchInput = document.getElementById('searchInput');
          if (searchInput) {
            searchInput.focus();
            searchInput.select();
          }
        }

        // Escape to clear search
        if (e.key === 'Escape') {
          const searchInput = document.getElementById('searchInput');
          if (searchInput && searchInput.value) {
            searchInput.value = '';
            window.applyFiltersAndSort?.();
          }
        }
      });
    </script>
  </body>
</html>
